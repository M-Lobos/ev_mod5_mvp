<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:backgroundTint="@color/card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_stroke">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!--shoe img -->
        <ImageView
            android:id="@+id/ShoeImg"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:background="@color/background_soft"
            android:src="@drawable/shoe_test_img"
            android:contentDescription="Product img" />

        <!-- Product Name -->
        <TextView
            android:id="@+id/txtShoeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/name_product"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <!-- product price -->
        <TextView
            android:id="@+id/txtShoePrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/price_product"
            android:textSize="16sp"
            android:textColor="@color/price_color"/>

        <!-- add btn -->
        <Button
            android:id="@+id/btnAgregar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/add_to_cart_btn"
            android:textAllCaps="false"
            android:backgroundTint="@color/cupcake_primary"
            android:textColor="@color/button_text"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>